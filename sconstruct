# Simple SCons script for producing a development-ready NVDA add-on layout.
# This is intentionally lightweight for repository use.
#
# Layout mirrors scripts/build_addon.py: the contents of addon/ and the
# bits_easy_runtime package are flattened so the dev tree matches what NVDA
# will see at runtime when the .nvda-addon is installed.

import os
from pathlib import Path

Import("env") if "env" in globals() else None

repo_root = Path(__file__).resolve().parent
build_dir = repo_root / "dist" / "addon"

if build_dir.exists():
    for root, dirs, files in os.walk(build_dir, topdown=False):
        for name in files:
            Path(root, name).unlink()
        for name in dirs:
            Path(root, name).rmdir()
else:
    build_dir.mkdir(parents=True)


def _stage(src: Path, dst: Path) -> None:
    if not src.exists():
        return
    if src.is_file():
        dst.parent.mkdir(parents=True, exist_ok=True)
        dst.write_bytes(src.read_bytes())
        return
    for root, dirs, files in os.walk(src):
        rel = Path(root).relative_to(src)
        out_dir = dst / rel
        out_dir.mkdir(parents=True, exist_ok=True)
        for name in files:
            in_path = Path(root, name)
            (out_dir / name).write_bytes(in_path.read_bytes())


# Flatten addon/* to the dev-tree root so globalPlugins/ etc. sit where NVDA
# expects them.
_stage(repo_root / "addon" / "globalPlugins", build_dir / "globalPlugins")
_stage(repo_root / "addon" / "doc", build_dir / "doc")
_stage(repo_root / "addon" / "locale", build_dir / "locale")
_stage(repo_root / "addon" / "installTasks.py", build_dir / "installTasks.py")
_stage(repo_root / "addon" / "bits_easy_settings.py", build_dir / "bits_easy_settings.py")
_stage(repo_root / "COPYING.txt", build_dir / "COPYING.txt")

# Config and runtime package land at the dev-tree root, matching the built zip.
_stage(repo_root / "config" / "hotkeys", build_dir / "config" / "hotkeys")
_stage(repo_root / "src" / "bits_easy_runtime", build_dir / "bits_easy_runtime")

print("Prepared development add-on tree at", build_dir)
